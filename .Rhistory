select(
is_building_open_or_boarded,                                    # ← TARGET
is_the_building_currently_vacant_or_occupied,
is_the_building_vacant_due_to_fire,
any_people_using_property_homeless_childen_gangs,
location_of_building_on_the_lot_if_garage_change_type_code_to_bgd,
if_the_building_is_open_where_is_the_entry_point,
community_area, ward, police_district,
year = as.factor(year(date_service_request_was_received)),
month = as.factor(month(date_service_request_was_received, label = TRUE))
) %>%
