) %>%
set_engine("rpart") %>%
set_mode("classification")
# -------------------------------
# 3) Fit the tree
# -------------------------------
tree_fit <- workflow() %>%
add_model(tree_spec) %>%
add_formula(is_building_open_or_boarded ~ .) %>%
fit(data = tree_data)
# -------------------------------
# 4) Extract and plot
# -------------------------------
final_tree <- tree_fit %>%
extract_fit_parsnip() %>%
pluck("fit")
# Plot a readable tree
rpart.plot(
final_tree,
type = 2,         # split labels below nodes
extra = 104,      # shows n and % in leaves
fallen.leaves = TRUE,
cex = 0.6,        # smaller text for better fit
tweak = 1.2,      # adjust node size
box.palette = "Greens",
varlen = 20,      # truncate long variable names
faclen = 15       # truncate factor levels
)
